{
  "host": "127.0.0.1",
  "port": 8080,
  "sessionTTL": 86400,
  "maxUploadSize": 52428800,
  "rateLimitWindow": 300,
  "rateLimitMaxAttempts": 5,
  "rateLimitBanDuration": 300,
  "jwtSecret": "change-this-to-a-long-random-string",
  "trustProxy": false,
  "logMode": "fmt",
  "logTag": "html-editor",
